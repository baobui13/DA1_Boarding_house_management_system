# Google Gemini API Key
# Đăng ký miễn phí tại: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# Hugging Face Token (dùng cho phân tích cảm xúc nâng cao)
# Đăng ký miễn phí tại: https://huggingface.co/settings/tokens
# (Có thể để trống nếu dùng rule-based fallback)
HUGGINGFACE_TOKEN=your-huggingface-token-here

# Port cho microservice (mặc định 8000)
PORT=8000
