{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_HOST;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Authentication": {
    "Google": {
      "ClientId": "your-google-client-id",
      "ClientSecret": "your-google-client-secret"
    }
  },
  "Jwt": {
    "Issuer": "BoardingHouseManagementSystemServer",
    "Audience": "BoardingHouseManagementSystemClient",
    "Key": "your-secret-jwt-key",
    "ExpireHours": 2
  },
  "CloudinarySettings": {
    "CloudName": "your-cloud-name",
    "ApiKey": "your-api-key",
    "ApiSecret": "your-api-secret",
    "Folder": "boarding-house-images-qlt-copy"
  },
  "AspectAnalysis": {
    "Enabled": true,
    "PythonServiceUrl": "http://localhost:8001/analyze",
    "RequestTimeoutSeconds": 10,
    "AspectPresenceThreshold": 0.5,
    "FallbackToKeywordOnError": true
  },
  "Recommendation": {
    "DefaultMode": "PersonalMatch",
    "BaseWeights": {
      "PersonalHistory": 1.0,
      "GlobalHistory": 0.55,
      "AspectMatch": 1.6,
      "AspectGlobalQuality": 0.65,
      "PriceFit": 28,
      "AreaMatch": 35,
      "AmenityMatchPerItem": 6,
      "MaxAmenityBonus": 22,
      "BaseScore": 10
    },
    "Profiles": {
      "HighAspectQuality": {
        "AspectMatch": 3.8,
        "PersonalHistory": 0.3,
        "GlobalHistory": 0.2,
        "AspectGlobalQuality": 1.0
      },
      "Balanced": {
        "AspectMatch": 2.0,
        "PersonalHistory": 1.0,
        "GlobalHistory": 0.7
      },
      "PriceSensitive": {
        "PriceFit": 55,
        "AspectMatch": 1.2,
        "PersonalHistory": 0.8
      },
      "Explore": {
        "PersonalHistory": 0.2,
        "GlobalHistory": 0.9,
        "AspectMatch": 1.8
      },
      "AvoidNegatives": {
        "AspectMatch": 2.2,
        "NegativeAspectPenaltyMultiplier": 2.8
      }
    }
  }
}
